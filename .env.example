# Example environment file.
# Copy this to ".env" and fill in values only if you need them.
# For normal local development you do NOT need any of these — the app
# runs on a local SQLite database with zero setup.

# --- Database ---
# Leave this UNSET to use the local SQLite database (data/local.db).
# Set it to a PostgreSQL connection string to use PostgreSQL instead,
# then run `npm run db:push` once to create the tables.
# DATABASE_URL=postgres://user:password@localhost:5432/onpoint

# --- Sessions ---
# A secret used to sign login cookies. Required in production.
# SESSION_SECRET=change-me-to-a-long-random-string

# --- Server ---
# Port the app listens on (defaults to 5000).
# PORT=5000
